# Public Expo env vars — inlined into the app bundle at build time (EXPO_PUBLIC_ prefix).
# Copy to .env and fill in. In CI these come from GitHub Actions secrets.

# RevenueCat public SDK keys.
# - EXPO_PUBLIC_REVENUECAT_KEY: platform key (appl_ iOS / goog_ Android). Used in
#   release builds, and in dev when no Test Store key is set (Apple/Google sandbox).
# - EXPO_PUBLIC_REVENUECAT_TEST_STORE_KEY: RevenueCat Test Store key (Apps &
#   providers → Test Store). Simulates purchases in __DEV__ builds with no
#   Apple/Google account. DEV-ONLY — never put this in a release build.
EXPO_PUBLIC_REVENUECAT_KEY=
EXPO_PUBLIC_REVENUECAT_TEST_STORE_KEY=

# Facebook App ID — required for the Instagram Stories share deep link.
EXPO_PUBLIC_FACEBOOK_APP_ID=

# Backend API base URL (looxmaxxing-api on Vercel). Used by src/services/api.ts.
# No trailing slash. Prod: https://looxmaxxing-api.vercel.app
EXPO_PUBLIC_API_BASE_URL=

# E2E mode — stubs scan/render API + shows "Use test photo" on web capture. Set by Playwright.
EXPO_PUBLIC_E2E=
