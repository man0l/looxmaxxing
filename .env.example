# Public Expo env vars — inlined into the app bundle at build time (EXPO_PUBLIC_ prefix).
# Copy to .env and fill in. In CI these come from GitHub Actions secrets.

# RevenueCat public SDK keys — each store app has its own key, so iOS and Android
# need separate values (see src/services/purchases.ts, branches on Platform.OS).
# - EXPO_PUBLIC_REVENUECAT_KEY: Android/Play Store key (goog_...). Also used as the
#   fallback on iOS if EXPO_PUBLIC_REVENUECAT_IOS_KEY isn't set.
# - EXPO_PUBLIC_REVENUECAT_IOS_KEY: iOS/App Store key (appl_...).
# - EXPO_PUBLIC_REVENUECAT_TEST_STORE_KEY: RevenueCat Test Store key (Apps &
#   providers → Test Store). Simulates purchases in __DEV__ builds with no
#   Apple/Google account. DEV-ONLY — never put this in a release build.
EXPO_PUBLIC_REVENUECAT_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_TEST_STORE_KEY=

# Facebook App ID — required for the Instagram Stories share deep link.
EXPO_PUBLIC_FACEBOOK_APP_ID=

# AppsFlyer attribution SDK.
# - EXPO_PUBLIC_APPSFLYER_DEV_KEY: Dev key from AppsFlyer dashboard (App settings).
# - EXPO_PUBLIC_APPSFLYER_APP_ID: iOS numeric App Store ID (required on iOS only,
#   leave blank until the iOS app is submitted). Android uses the package name
#   (`app.json` → `expo.android.package`) automatically, no env var needed.
EXPO_PUBLIC_APPSFLYER_DEV_KEY=
EXPO_PUBLIC_APPSFLYER_APP_ID=

# Backend API base URL (looxmaxxing-api on Vercel). Used by src/services/api.ts.
# No trailing slash. Prod: https://looxmaxxing-api.vercel.app
EXPO_PUBLIC_API_BASE_URL=https://looxmaxxing-api.vercel.app

# E2E mode — stubs scan/render API + shows "Use test photo" on web capture. Set by Playwright.
EXPO_PUBLIC_E2E=
