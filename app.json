{
  "expo": {
    "name": "looxmaxxing",
    "slug": "looxmaxxing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "instagram",
          "instagram-stories",
          "twitter",
          "whatsapp",
          "tiktok",
          "snssdk1233"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.balkanbit.looxmaxxing",
      "versionCode": 3,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withShareIntentQueries",
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "expo-video",
      "expo-sensors",
      [
        "expo-camera",
        {
          "cameraPermission": "Axend uses your camera to capture the front and profile photos used to generate your trait scores.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Axend accesses your photos so you can pick an existing selfie for your scan."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4b533d40-0092-4fe1-98b9-6fd270e1745b"
      }
    },
    "owner": "man0l"
  }
}
