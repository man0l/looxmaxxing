+package cl.json.social;
+
+import android.content.ActivityNotFoundException;
+
+import com.facebook.react.bridge.ReactApplicationContext;
+import com.facebook.react.bridge.ReadableMap;
+
+/**
+ * Direct share to TikTok via package-targeted ACTION_SEND.
+ * TikTok still uses com.zhiliaoapp.musically (US/global) or
+ * com.ss.android.ugc.trill (some other regions).
+ */
+public class TikTokShare extends SingleShareIntent {
+
+    private static final String PACKAGE_GLOBAL = "com.zhiliaoapp.musically";
+    private static final String PACKAGE_REGIONAL = "com.ss.android.ugc.trill";
+
+    public TikTokShare(ReactApplicationContext reactContext) {
+        super(reactContext);
+    }
+
+    @Override
+    public void open(ReadableMap options) throws ActivityNotFoundException {
+        super.open(options);
+        this.openIntentChooser();
+    }
+
+    @Override
+    protected String getPackage() {
+        if (ShareIntent.isPackageInstalled(PACKAGE_GLOBAL, this.reactContext)) {
+            return PACKAGE_GLOBAL;
+        }
+        if (ShareIntent.isPackageInstalled(PACKAGE_REGIONAL, this.reactContext)) {
+            return PACKAGE_REGIONAL;
+        }
+        return PACKAGE_GLOBAL;
+    }
+
+    @Override
+    protected String getDefaultWebLink() {
+        return null;
+    }
+
+    @Override
+    protected String getPlayStoreLink() {
+        return "https://play.google.com/store/apps/details?id=com.zhiliaoapp.musically";
+    }
+}
